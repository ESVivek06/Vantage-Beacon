# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here

# ── Database (see packages/database/.env.example for regional URLs) ───────────
DATABASE_URL="postgresql://vb_user:password@localhost:5432/vb_local?schema=public"
DEFAULT_REGION=UK

# ── Redis / BullMQ ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# SES — use sandbox mode in dev; request production access via AWS console
SES_FROM_ADDRESS=noreply@vb.com

# ── Email ─────────────────────────────────────────────────────────────────────
# Secret for HMAC-based unsubscribe tokens — MUST be set in production
UNSUBSCRIBE_SECRET=change-me-in-production

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
