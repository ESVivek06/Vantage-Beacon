# API
PORT=3001
NODE_ENV=development

# Database — local dev (Postgres 16 + pgvector required)
# See packages/database/.env.example for full regional cluster config
DATABASE_URL="postgresql://vb_user:password@localhost:5432/vb_local?schema=public"
DATABASE_URL_UK="postgresql://vb_user:password@localhost:5432/vb_local?schema=public"
DATABASE_URL_NA="postgresql://vb_user:password@localhost:5432/vb_local?schema=public"
DATABASE_URL_IN="postgresql://vb_user:password@localhost:5432/vb_local?schema=public"
DEFAULT_REGION="UK"

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# NextAuth.js v5
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"
AUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth — https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Upstash Redis — https://console.upstash.com
# Used for refresh token storage and session revocation
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
