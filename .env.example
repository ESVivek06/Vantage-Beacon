# API
PORT=3001
NODE_ENV=development

# Database — local dev (Postgres 16 + pgvector required)
# See packages/database/.env.example for full regional cluster config
DATABASE_URL="postgresql://vb_user:password@localhost:5432/vb_local?schema=public"
DATABASE_URL_UK="postgresql://vb_user:password@localhost:5432/vb_local?schema=public"
DATABASE_URL_NA="postgresql://vb_user:password@localhost:5432/vb_local?schema=public"
DATABASE_URL_IN="postgresql://vb_user:password@localhost:5432/vb_local?schema=public"
DEFAULT_REGION="UK"

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
