{
  "name": "vb-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"yarn workspace @vb/api dev\" \"yarn workspace @vb/web dev\"",
    "build": "yarn workspaces run build",
    "lint": "yarn workspaces run lint",
    "test": "yarn workspaces run test",
    "typecheck": "yarn workspaces run typecheck",
    "db:generate": "yarn workspace @vb/database db:generate",
    "db:migrate:dev": "yarn workspace @vb/database db:migrate:dev",
    "db:migrate:deploy": "yarn workspace @vb/database db:migrate:deploy",
    "db:migrate:reset": "yarn workspace @vb/database db:migrate:reset",
    "db:seed": "yarn workspace @vb/database db:seed",
    "db:studio": "yarn workspace @vb/database db:studio"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "babel-jest": "^30.4.1",
    "concurrently": "^8.2.0",
    "import-local": "^3.2.0",
    "jest": "^30.4.2",
    "jest-cli": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=1.22.0"
  }
}
