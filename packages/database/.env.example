# ── Default (local dev / migrations) ──────────────────────────────────────────
# Used by: prisma migrate dev, prisma studio, seed script
DATABASE_URL="postgresql://vb_user:password@localhost:5432/vb_local?schema=public"

# ── Regional cluster URLs (production) ────────────────────────────────────────
# Each region has an isolated RDS PostgreSQL 16 + pgvector instance.
# The API Gateway routes requests to the correct regional service using the JWT region claim.
# Falls back to DATABASE_URL when not set (useful for single-region staging environments).

# UK — eu-west-2 (London) — UK GDPR / DPA 2018
DATABASE_URL_UK="postgresql://vb_user:password@vb-uk.cluster-xxxx.eu-west-2.rds.amazonaws.com:5432/vb_uk?schema=public&connection_limit=10&pool_timeout=20"

# North America — us-east-1 (Virginia) — CCPA / PIPEDA
DATABASE_URL_NA="postgresql://vb_user:password@vb-na.cluster-xxxx.us-east-1.rds.amazonaws.com:5432/vb_na?schema=public&connection_limit=10&pool_timeout=20"

# India — ap-south-1 (Mumbai) — PDPB 2023 [Phase 2 — not live yet]
DATABASE_URL_IN="postgresql://vb_user:password@vb-in.cluster-xxxx.ap-south-1.rds.amazonaws.com:5432/vb_in?schema=public&connection_limit=10&pool_timeout=20"

# ── Misc ───────────────────────────────────────────────────────────────────────
# Region used by getClient() in single-region local dev / CI environments
DEFAULT_REGION="UK"
